# Copy to .env, fill in values, then `set -a && source .env && set +a` before
# launching Claude Code in this directory (or use direnv).

# Used by browser-use's autonomous agent tool (retry_with_browser_use_agent).
# Most operations don't need it — only multi-step autonomous flows do.
ANTHROPIC_API_KEY=

# Reference value used by playbooks. Not consumed by browser-use itself.
# Detected at runtime from the live browser session; this is just a
# placeholder so playbooks have a name to refer to.
HN_HANDLE=failproofai
